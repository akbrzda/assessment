{
  "name": "assessment-backend",
  "version": "1.0.0",
  "description": "API для системы аттестаций сотрудников",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "migrate": "node database/runMigrations.js",
    "phase0:diagnostics": "node scripts/phase0-diagnostics.js",
    "phase1:recalculate-matching": "node scripts/recalculate-matching-attempts.js",
    "phase4:explain": "node scripts/phase4-explain-top5.js",
    "test:smoke:admin": "node --test tests/admin-smoke.test.js",
    "test:assessment": "node --test tests/assessment.score-answer.test.js",
    "test:phase4": "node --test tests/phase4.integration.test.js",
    "test:courses": "node --test tests/courses/topics.completion.test.js tests/courses/sections.completion.test.js tests/courses/progress.calculation.test.js tests/courses/assignments.filter.test.js tests/courses/course.e2e.test.js tests/courses/analytics.repository.test.js",
    "test": "node --test tests/admin-smoke.test.js tests/assessment.score-answer.test.js tests/phase4.integration.test.js tests/courses/topics.completion.test.js tests/courses/sections.completion.test.js tests/courses/progress.calculation.test.js tests/courses/assignments.filter.test.js tests/courses/course.e2e.test.js tests/courses/analytics.repository.test.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bullmq": "^5.75.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-validator": "^7.3.1",
    "ioredis": "^5.10.1",
    "joi": "^17.12.1",
    "jsonwebtoken": "^9.0.2",
    "moment-timezone": "^0.6.0",
    "multer": "^1.4.5-lts.2",
    "mysql2": "^3.9.7",
    "pdfkit": "^0.17.2",
    "socket.io": "^4.8.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
